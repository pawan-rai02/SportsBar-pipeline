# SportsBar Pipeline - .gitignore

# Ignore data files (CSV, Excel, etc.)
*.csv
*.xlsx
*.xls
*.parquet
*.json
*.xml

# Ignore large binary files (except images folder)
*.jpg
*.jpeg
*.pdf
*.zip
*.tar
*.gz

# Allow images in the images folder
!images/*.png
!images/*.jpg
!images/*.jpeg
!images/*.gif
!images/*.svg

# Databricks specific
.databricks/
*.dbc
__pycache__/
*.pyc

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Environment variables
.env
.env.local
.env.*.local

# Python virtual environments
venv/
env/
.venv/

# Jupyter notebooks (if not tracking)
*.ipynb_checkpoints/

# Temporary files
tmp/
temp/
*.tmp

# Build outputs
dist/
build/
*.egg-info/
